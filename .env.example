# Postgres — default points at the local container in docker-compose.yml.
DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm_agents

# UI auth — user signs in at /login with MASTER_KEY; UI_USERNAME is display only
UI_USERNAME=admin
MASTER_KEY=

# Sandbox backend — `fargate` (AWS ECS) or `k8s` (Kubernetes via the
# kubernetes-sigs/agent-sandbox CRD). For local development with kind see
# bin/kind-up.sh, then set SANDBOX_BACKEND=k8s. AWS_* and K8S_* knobs are
# only required for their respective backends.
SANDBOX_BACKEND=fargate

# Kubernetes backend — only used when SANDBOX_BACKEND=k8s.
#   K8S_NAMESPACE        namespace Sandbox CRs and Services live in
#   K8S_NODE_HOST        host the web container reaches the kind/k8s node on.
#                        For docker-compose use host.docker.internal (default);
#                        for `next dev` directly on macOS/Linux use 127.0.0.1.
#   K8S_NODEPORT_MIN/MAX NodePort range exposed on the host (must match
#                        kind's extraPortMappings — see bin/kind-up.sh).
#   K8S_IMAGE_PULL_POLICY Use Never for kind-loaded local images, IfNotPresent
#                        or Always for registry-backed images.
#   K8S_HARNESS_IMAGE    Container image for the opencode harness pod.
K8S_NAMESPACE=default
K8S_NODE_HOST=host.docker.internal
K8S_NODEPORT_MIN=30000
K8S_NODEPORT_MAX=30099
K8S_IMAGE_PULL_POLICY=Never
K8S_HARNESS_IMAGE=opencode-sandbox:dev
# Override kubeconfig cluster server URL — set this when the kubeconfig on
# disk points at a host that the running process can't reach. For
# docker-compose this is the kind apiserver pinned at host.docker.internal:6444
# by bin/kind-up.sh. Leave blank when running `next dev` directly on the host.
K8S_API_SERVER=

# AWS — only required when SANDBOX_BACKEND=fargate. Needs ECS / ECR / EC2 /
# IAM / Logs / STS perms. Credentials are resolved by the SDK's default
# provider chain — pick whichever fits:
#   • paste the two env vars below
#   • set AWS_PROFILE and let ~/.aws/credentials (or SSO cache) handle it
#   • leave everything blank if you're on EC2/ECS with an instance role
AWS_REGION=us-east-1
AWS_CLUSTER=litellm-agents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PROFILE=

# Filled in by ./setup.sh — paste output here, then restart server
AWS_TASK_DEFINITION_ARN=
AWS_SUBNETS=                 # comma-separated subnet IDs (public)
AWS_SECURITY_GROUP=

# Repo cloned into sandbox at session start (used when agent.repo_url is null)
PREINSTALLED_GITHUB_REPO=https://github.com/BerriAI/litellm

# LiteLLM model gateway — passed into container as env so harness can call models
LITELLM_API_BASE=https://your-litellm-proxy.example.com
LITELLM_API_KEY=sk-...

# Optional tuning
CONTAINER_PORT=4096
RECONCILE_INTERVAL_SECONDS=60

# Warm pool — pre-provisioned Fargate tasks waiting to be claimed by a
# session create. Default of 2 keeps two tasks ready for the most
# recently active agent so users get sub-5s session creates out of the box
# (~$32/mo at 512 CPU / 1024 mem). Set WARM_POOL_SIZE=0 to disable.
#   WARM_POOL_SIZE                 total target across all agents
#   WARM_POOL_MAX_PROVISIONING     concurrency cap on the top-up loop
#   WARM_POOL_TTL_MINUTES          recycle warm tasks older than this
#   WARM_POOL_RECENT_AGENT_HOURS   ignore agents not used in the last N hours
WARM_POOL_SIZE=2
WARM_POOL_MAX_PROVISIONING=2
WARM_POOL_TTL_MINUTES=30
WARM_POOL_RECENT_AGENT_HOURS=24

# Anything matching CONTAINER_ENV_* is injected into every Fargate container,
# with the prefix stripped. Example:
# CONTAINER_ENV_GITHUB_TOKEN=ghp_...   →   container sees GITHUB_TOKEN=ghp_...
